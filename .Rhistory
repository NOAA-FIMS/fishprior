knitr::opts_chunk$set(echo = TRUE)
library(fishprior)
library(ggplot2)
library(dplyr)
library(knitr)
m <- data.frame("FishBase tables used" = c("rfishbase::popgrowth",
"rfishbase::popchar",
"rfishbase::poplw",
"rfishbase::maturity",
"rfishbase::fecundity"))
knitr::kable(m)
species_list <- c(
"Scomber scombrus"
)
example_base_raw <- get_fishbase_traits(spec_names = species_list)
example_base_raw
example_base_raw |>
dplyr::filter(Number > 0) |>
dplyr::group_by(trait) |>
dplyr::summarise(value = dplyr::n()) |>
ggplot(aes(trait, value)) + geom_bar(stat = "identity") +
labs(x = "", y = "Sample size",
title="Reported sample sizes for European mackerel studies") +
theme_bw()
filtered_traits <- dplyr::filter(example_base_raw,
Number > 0,
trait %in% c("LengthMax"))
weighted_summary <- filtered_traits |>
dplyr::summarise(
weighted_mean = weighted.mean(value, w = Number),
simple_mean = mean(value),
weighted_var = sum(Number * (value - weighted_mean)^2) / sum(Number),
weighted_se = sqrt(weighted_var / dplyr::n()),
total_n = sum(Number),
n_studies = dplyr::n()
)
weighted_summary
filtered_traits |>
ggplot(aes(value)) + geom_histogram() +
labs(x = "", y = "Count",
title="Maximum lengths in European mackerel studies") +
theme_bw() +
geom_vline(aes(xintercept = weighted_summary$weighted_mean - 1.96*weighted_summary$weighted_se), col = "blue", linetype=2) +
geom_vline(aes(xintercept = weighted_summary$weighted_mean + 1.96*weighted_summary$weighted_se), col = "blue", linetype=2) +
geom_vline(aes(xintercept = weighted_summary$weighted_mean), col = "blue", linewidth=1.1)
library(brms)
filtered_traits$sqrt_n <- 1 / sqrt(filtered_traits$Number)
filtered_traits$study_id <- seq_len(nrow(filtered_traits))
filtered_traits$log_n <- log(filtered_traits$value)
formula <- bf(
log_n ~ 1,
sigma ~ 0 + sqrt_n
)
fit <- brm(
formula,
data = filtered_traits,
family = gaussian(),
chains = 4,
iter = 5000,
control = list(adapt_delta = 0.999)
)
species_list <- c(
"Anoplopoma fimbria")
sablefish_traits <- get_fishbase_traits(spec_names = species_list)
filtered_traits <- dplyr::filter(sablefish_traits,
SE > 0,
trait %in% c("K"))
fit
knitr::kable(filtered_traits[,c("Locality","value", "SE")])
ak_traits <- dplyr::filter(filtered_traits,
Locality %in% c("Gulf of Alaska"))
ak_tria
ak_traits
ak_traits[,"SE"]
ak_traits$study <- seq_len(nrow(ak_traits))
fit <- brm(value | se(SE) ~ 1 + (1 | study), data = ak_traits,
control = list(adapt_delta = 0.999))
fit
fit <- brm(value | se(SE, sigma=TRUE) ~ 1 + (1 | study), data = ak_traits,
control = list(adapt_delta = 0.999))
fit
knitr::kable(filtered_traits[,c("Locality","value", "SE")])
fit1 <- brm(
value | se(SE) ~ 1,
data = ak_traits,
prior = prior(normal(0, 10), class = Intercept),
chains = 4, iter = 2000,
control = list(adapt_delta = 0.999)
)
fit1
fit2 <- brm(
value | se(SE, sigma = TRUE) ~ 1,
data = ak_traits,
prior = c(
prior(normal(0, 10), class = Intercept),
prior(exponential(1), class = sigma)
),
chains = 4, iter = 2000,
control = list(adapt_delta = 0.999)
)
$fit2
fit2
fit3 <- brm(
value | se(SE, sigma = TRUE) ~ 1 + (1 | study),
data = ak_traits,
prior = c(
prior(normal(0, 10), class = Intercept),
prior(exponential(1), class = sigma),
prior(exponential(1), class = sd)
),
chains = 4, iter = 2000,
control = list(adapt_delta = 0.999)
)
fit3
