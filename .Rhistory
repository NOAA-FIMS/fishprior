weighted_summary <- filtered_traits |>
group_by(trait) |>
summarise(
weighted_mean = weighted.mean(value, w = Number),
simple_mean = mean(value),
weighted_var = sum(Number * (value - weighted_mean)^2) / sum(Number),
weighted_se = sqrt(weighted_var / n()),
total_n = sum(Number),
n_studies = n()
)
